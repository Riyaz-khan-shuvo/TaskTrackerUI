@model TaskTracker.Models.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

@section Style {
    <style>
        .auth-section {
            background: linear-gradient(135deg, #f8fff9, #eaf7eb);
            min-height: 100vh;
            padding-top: 60px;
            padding-bottom: 60px;
        }

        .auth-card {
            background: #fff;
            border-radius: 16px;
            transition: all 0.3s ease;
        }

          /*   .auth-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(46, 125, 50, 0.15);
            } */

        .auth-form input.form-control {
            border: 1px solid #dcdcdc;
            padding: 10px 14px;
        }

            .auth-form input.form-control:focus {
                border-color: #2E7D32;
                box-shadow: 0 0 0 0.15rem rgba(46, 125, 50, 0.2);
            }

        .auth-form button:hover {
            background-color: #256628 !important;
        }
    </style>
}

<section class="auth-section py-5 d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center align-items-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0 rounded-4 auth-card p-4">
                    <div class="text-center mb-4">
                        <img src="~/Content/adminlte/dist/img/logo.png" alt="Task Tracker" style="height: 40px;">
                        <h2 class="fw-bold mt-3" style="color: #2E7D32;">Reset Password</h2>
                        <p class="text-muted">Set your new password below</p>
                    </div>

                    <form asp-action="ResetPassword" asp-controller="Account" method="post" class="auth-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="Token" />

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                            <input asp-for="NewPassword" type="password" class="form-control rounded-3" placeholder="Enter new password" required />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control rounded-3" placeholder="Confirm password" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn w-100 py-2 text-white fw-semibold shadow-sm" style="background-color: #2E7D32; border-radius: 10px;">
                            Reset Password
                        </button>

                        <div class="text-center mt-3">
                            <p class="text-muted mb-0">
                                Back to <a asp-controller="Account" asp-action="Login" style="color:#2E7D32; font-weight:600;">Login</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
