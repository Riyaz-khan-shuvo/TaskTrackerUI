@model TaskTracker.Models.Auth.LoginViewModel

@{
    ViewData["Title"] = "Login";
}


@section Style {
    <style>
        .auth-section {
            background: linear-gradient(135deg, #f8fff9, #eaf7eb);
            /* min-height: calc(100vh - 120px); */
        }

        .auth-card {
            background: #fff;
            border-radius: 16px;
            transition: all 0.3s ease;
        }

            /* .auth-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 25px rgba(46, 125, 50, 0.15);
            } */

        .auth-form input.form-control {
            border: 1px solid #dcdcdc;
            padding: 10px 14px;
            transition: all 0.2s ease;
        }

            .auth-form input.form-control:focus {
                border-color: #2E7D32;
                box-shadow: 0 0 0 0.15rem rgba(46, 125, 50, 0.2);
            }

        .auth-form button:hover {
            background-color: #256628 !important;
        }

    </style>
}

<section class="auth-section py-5">
    <div class="container">
        <div class="row justify-content-center align-items-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0 rounded-4 auth-card p-4">
                    <div class="text-center mb-4">
                        @* <img src="~/Content/adminlte/dist/img/logo.png" alt="Task Tracker" style="height: 40px;"> *@
                        <h2 class="fw-bold mt-3" style="color: #2E7D32;">Sign In</h2>
                        <p class="text-muted">Welcome back! Please login to your account</p>
                    </div>

                    <form asp-action="Login" asp-controller="Account" method="post" class="auth-form">
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control rounded-3" placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <input asp-for="Password" class="form-control rounded-3" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <input asp-for="RememberMe" type="checkbox" />
                                <label asp-for="RememberMe" class="text-muted small"></label>
                            </div>
                            <a asp-controller="Account" asp-action="ForgetPassword" class="text-decoration-none small" style="color:#2E7D32;">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn w-100 py-2 text-white fw-semibold shadow-sm" style="background-color: #2E7D32; border-radius: 10px;">
                            Sign In
                        </button>

                        <div class="text-center mt-3">
                            <p class="text-muted mb-0">
                                Don’t have an account?
                                <a asp-controller="Account" asp-action="Register" style="color:#2E7D32; font-weight:600;">Sign Up</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "5000"
            };

            @if (TempData["Success"] != null)
            {
                        <text>toastr.success('@TempData["Success"]');</text>
            }

            @if (TempData["Error"] != null)
            {
                        <text>toastr.error('@TempData["Error"]');</text>
            }
        });
    </script>
}

