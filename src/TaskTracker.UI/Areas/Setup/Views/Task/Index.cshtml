@using TaskTracker.Shared.ApiClients
@model TaskItemModel

@{
    ViewData["Title"] = "Task";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Task</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/Setup/Task">Task</a></li>
                    <li class="breadcrumb-item active">Index</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card">
        <div class="card-header p-2">
            <a id="btnNew"
               class="button NewButton addNewButton"
               asp-area="Setup"
               asp-controller="Task"
               asp-action="Upsert">
                New
            </a>

            <button id="btnDelete"
                    type="button"
                    title="Delete"
                    class="button sslUnPost btnDelete">
                Delete
            </button>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card card-secondary">
        <div class="card-header">
            <h3 class="card-title">List of Tasks</h3>
        </div>

        <div class="card-body">
            <div id="GridData"></div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="/js/Services/CommonAjaxService.js"></script>
    <script src="/js/Controllers/TaskController.js"></script>

    <script>
        $(document).ready(function () {
            TaskController.init();
        });
    </script>
}