@model TaskTracker.Models.UserRoleViewModel

@{
    ViewBag.Title = "User Role Create";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"> User Role </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li id="btnBack"><img src="~/Content/css/ButtonsIcons/back-icon.png" title="Click for Go Back" /></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <form id="frm_role" enctype="multipart/form-data" method="post">
        <div class="card card-secondary">
            <div class="card-header">
                <h3 class="card-title"> User Role Info </h3>
            </div>

            <div class="card-body">

                <input asp-for="Id" type="hidden" />
                <input asp-for="Operation" type="hidden" />

                <div class="col-sm-4">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control form-control-sm" placeholder="Enter Role Name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="card ">
            <div class="d-flex justify-content-between">
                <div class="card-header p-2">
                    <div>
                        <button id="btnSave" type="button" class="button btnsave sslSave">Save</button>
                    </div>
                </div>

                <div class="auditshow"> <img src="~/Content/Images/audit.png" title="Click for Audit" /> </div>
            </div>
        </div>


    </form>



</div>


@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="/js/Services/CommonAjaxService.js"></script>
    <script src="/js/Controllers/MenuAuthorizationController.js"></script>
    <script>
        $(document).ready(function () {
            MenuAuthorizationController.init();
        });
    </script>
}